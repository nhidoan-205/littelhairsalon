@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Đăng Nhập";
    
}
<style>
    /* --- CSS CHUẨN TÔNG ĐEN/VÀNG CỦA LITTLEHAIRSALON --- */
    :root {
        --salon-primary: #FFCC00; /* Màu vàng gold menu */
        --salon-dark: #111111;    /* Màu đen tuyền */
    }

    .login-wrapper {
        background-color: #f4f6f8;
        min-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 1rem;
    }

    .login-card {
        background: white;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        width: 100%;
        max-width: 28rem; /* Form đăng nhập nhỏ gọn hơn form đăng ký */
        position: relative;
        z-index: 10;
        overflow: hidden;
        border: 1px solid #e2e8f0;
        transition: transform 0.5s ease;
    }
    .login-card:hover {
        transform: scale(1.005);
    }

    /* Header Đen chữ Vàng */
    .login-header {
        background-color: var(--salon-dark);
        padding: 2rem;
        text-align: center;
        border-bottom: 4px solid var(--salon-primary);
    }
    .login-header h2 {
        color: var(--salon-primary);
        font-weight: 700;
        font-size: 1.5rem;
        margin: 0;
        display: flex; 
        align-items: center; 
        justify-content: center; 
        gap: 8px;
    }

    .login-body {
        padding: 2.5rem 2rem;
    }
    
    .login-label {
        display: block; 
        font-size: 0.875rem; 
        font-weight: 700; 
        color: #000000 !important; /* Ép chữ màu đen */
        margin-bottom: 0.5rem; 
    }
    
    .login-input {
        width: 100%; 
        padding: 0.875rem 1.25rem; 
        border-radius: 0.5rem;
        border: 1px solid #cbd5e1; 
        background-color: #f8fafc; 
        color: #0f172a;
        outline: none; 
        transition: all 0.3s;
    }
    .login-input:focus {
        border-color: var(--salon-primary);
        box-shadow: 0 0 0 3px rgba(255, 204, 0, 0.2);
        background-color: white;
    }

    /* Nút bấm Đen chữ Vàng */
    .btn-login-submit {
        width: 100%; 
        background-color: var(--salon-dark); 
        color: var(--salon-primary);
        font-weight: 700; 
        font-size: 1rem;
        padding: 1rem; 
        border-radius: 0.5rem; 
        border: none;
        margin-top: 1rem; 
        transition: all 0.2s; 
    }
    .btn-login-submit:hover {
        background-color: #222222; 
        transform: translateY(-2px); 
    }
    .btn-login-submit:active {
        transform: scale(0.95);
    }
</style>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-header">
            <h2>
                ✂️ Đăng Nhập
            </h2>
        </div>
        
        <div class="login-body">
            <form asp-controller="TaiKhoan" asp-action="DangNhap" method="POST">
                @Html.AntiForgeryToken()
               
                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-danger rounded-3 small text-center mb-4 border-0" style="background-color: #fde8e8; color: #9b1c1c;">
                        @TempData["Message"]
                    </div>
                }

                <div class="mb-4">
                    <label class="login-label" for="TenDangNhap">Tên đăng nhập</label>
                    <input type="text" id="TenDangNhap" name="TenDangNhap" class="login-input" placeholder="Nhập username..." required />
                </div>
                
                <div class="mb-4">
                    <label class="login-label" for="MatKhau">Mật khẩu</label>
                    <input type="password" id="MatKhau" name="MatKhau" class="login-input" placeholder="Nhập mật khẩu..." required />
                </div>
                
                <button type="submit" class="btn-login-submit">ĐĂNG NHẬP NGAY</button>
            </form>

            <div class="d-flex align-items-center my-4">
                <hr class="flex-grow-1" style="border-color: #e2e8f0;">
                <span class="px-3 small text-muted" style="font-weight: 600;">HOẶC</span>
                <hr class="flex-grow-1" style="border-color: #e2e8f0;">
            </div>
              <a asp-controller="TaiKhoan" asp-action="LoginWithGoogle" class="btn w-100 d-flex align-items-center justify-content-center" style="height: 3.2rem; border: 1px solid #cbd5e1; border-radius: 0.5rem; background-color: white; color: #0f172a; font-weight: 600; text-decoration: none; transition: all 0.2s;">
                <svg viewBox="0 0 24 24" style="width: 20px; height: 20px; margin-right: 10px;">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
                Tiếp tục với Google
            </a>
            <a href="/TaiKhoan/LoginWithFacebook"
               class="btn d-flex align-items-center justify-content-center gap-2 w-100 py-2 fw-bold"
               style="background:#1877F2; color:#fff; border-radius:50px;">
                <i class="fa-brands fa-facebook"></i> Đăng nhập bằng Facebook
            </a>
            <div class="text-center pt-4">
                <p class="small mb-0" style="color: #64748b;">
                    Chưa có tài khoản? 
                    <a asp-controller="TaiKhoan" asp-action="DangKy" class="fw-bold text-decoration-none" style="color: #000000; text-decoration: underline !important;">Đăng ký ngay</a>
                </p>
            </div>

        </div> 
    </div> 
</div>