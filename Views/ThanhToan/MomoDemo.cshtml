@{
    ViewData["Title"] = "Thanh toán MoMo";
}

<style>
    body {
        background: #000;
    }

    .momo-wrap {
        max-width: 500px;
        margin: 60px auto;
        background: #111;
        border-radius: 1.5rem;
        border: 1px solid #222;
        padding: 40px;
        text-align: center;
    }

    .momo-header {
        background: linear-gradient(135deg, #ae2070, #d82d8b);
        border-radius: 1rem;
        padding: 20px;
        margin-bottom: 24px;
    }

    .qr-box {
        background: #fff;
        border-radius: 1rem;
        padding: 16px;
        display: inline-block;
        margin: 16px auto;
    }

    .btn-gold {
        background: #ffd700;
        color: #000;
        border: none;
        border-radius: 50px;
        padding: 12px 32px;
        font-weight: 700;
        text-decoration: none;
        display: inline-block;
        margin-top: 16px;
        transition: 0.2s;
    }

        .btn-gold:hover {
            background: #fff;
            color: #000;
        }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #1a1a1a;
        font-size: 0.9rem;
    }

        .info-row:last-child {
            border-bottom: none;
        }
</style>

<div class="momo-wrap">
    <div class="momo-header">
        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/9/91/MoMo_Logo.png/200px-MoMo_Logo.png"
             height="50" alt="MoMo" onerror="this.style.display='none'">
        <h5 class="text-white fw-bold mt-2 mb-0">Thanh toán qua MoMo</h5>
    </div>

    <p style="color:#aaa; font-size:0.9rem;">Quét mã QR bằng app MoMo để thanh toán</p>

    <div class="qr-box">
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=MoMo|LittleHairSalon|@ViewBag.MaDon|@ViewBag.SoTien"
             style="width:220px; height:220px;" alt="QR MoMo">
    </div>

    <div style="background:#0a0a0a; border:1px solid #222; border-radius:1rem; padding:16px; margin-top:16px; text-align:left;">
        <div class="info-row">
            <span style="color:#aaa;">Mã đơn hàng</span>
            <span style="color:#fff; font-weight:700;">#@ViewBag.MaDon</span>
        </div>
        <div class="info-row">
            <span style="color:#aaa;">Số tiền</span>
            <span style="color:#ae2070; font-weight:700;">@(((decimal)ViewBag.SoTien).ToString("#,##0"))₫</span>
        </div>
        <div class="info-row">
            <span style="color:#aaa;">Nội dung</span>
            <span style="color:#fff; font-weight:700;">Thanh toan don hang @ViewBag.MaDon</span>
        </div>
        <div class="info-row">
            <span style="color:#aaa;">Số điện thoại</span>
            <span style="color:#fff; font-weight:700;">079 274 5xxx</span>
        </div>
    </div>

    <div class="mt-3 p-3 rounded-3" style="background:#1a0a00; border:1px solid #ae2070;">
        <p style="color:#aaa; font-size:0.82rem; margin:0;">
            ⚠️ Sau khi thanh toán, vui lòng chụp màn hình và gửi về Hotline
            <strong style="color:#ae2070;">1900 8682</strong> để xác nhận đơn hàng.
        </p>
    </div>

    <a href="/KhachHang/DonHangCuaToi" class="btn-gold mt-3">
        📦 Xem đơn hàng của tôi
    </a>
</div>