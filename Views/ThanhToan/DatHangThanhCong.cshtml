@model LittleHairSalon.Models.DonHang
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container my-5 text-center">
    <div class="card shadow-lg p-5 border-0" style="border-radius: 20px;">
        <div class="mb-4">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
        </div>
        <h2 class="text-success fw-bold">ĐẶT HÀNG THÀNH CÔNG!</h2>
        <p class="text-muted">Mã đơn hàng của bạn là: <strong>#@Model.MaDon</strong></p>
        @* CHỈ HIỆN MÃ QR NẾU KHÁCH CHỌN CHUYỂN KHOẢN *@
        @if (ViewBag.LoaiThanhToan == "NGANHANG")
        {
            <div class="mt-4 p-4 bg-light rounded border border-warning">
                <h5 class="text-danger fw-bold"><i class="bi bi-qr-code-scan"></i> THÔNG TIN CHUYỂN KHOẢN</h5>
                <hr>
                <div class="row align-items-center">
                    <div class="col-md-6">
                        @* Link QR MB Bank mới của Hương *@
                        <img src="https://img.vietqr.io/image/MB-259221274705-compact2.jpg?amount=@ViewBag.TongTien&addInfo=Thanh%20toan%20don%20hang%20@Model.MaDon"
                             alt="Ma QR Thanh Toan" class="img-fluid rounded shadow-sm" style="max-width: 250px;">
                    </div>
                    <div class="col-md-6 text-start">
                        <p><strong>Ngân hàng:</strong> MB Bank (Quân Đội)</p>
                        <p><strong>Số tài khoản:</strong> <span class="text-primary fs-5">259221274705</span></p>
                        <p><strong>Chủ tài khoản:</strong> VO NGUYEN HUYNH HUONG</p>
                        <p><strong>Số tiền:</strong> <span class="text-danger fs-5 fw-bold">@ViewBag.TongTien.ToString("#,##0")₫</span></p>
                        <p class="small text-muted"><i>* Nội dung: Thanh toan don hang @Model.MaDon</i></p>
                    </div>
                </div>
            </div>
        }
        else
        {
            <p>Cảm ơn bạn đã tin tưởng mua sắm tại <strong>LittleHairSalon</strong>.</p>
            <p>Đơn hàng của bạn đang được xử lý và sẽ giao trong thời gian sớm nhất.</p>
        }

        <div class="mt-5 d-flex justify-content-center gap-3">
            <a href="/" class="btn btn-outline-primary px-4 py-2">← Quay về trang chủ</a>
            <a href="/KhachHang/DonHangCuaToi" class="btn btn-primary px-4 py-2">Xem đơn hàng →</a>
        </div>
    </div>
</div>