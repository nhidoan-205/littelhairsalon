@model List<LittleHairSalon.Models.GioHangItem>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<style>
    /* UI System 2026 */
    :root {
        --leaf-green: #5A7D65;
        --leaf-accent: #A8D5BA;
        --leaf-bg: #F9FDF9;
        --card-bg: #FFFFFF;
    }

    body {
        background-color: #F5F7FA;
    }

    .cart-header {
        text-align: center;
        margin-bottom: 40px;
        position: relative;
    }

        .cart-header h2 {
            font-weight: 800;
            color: var(--leaf-green);
            letter-spacing: -0.5px;
        }

    /* Card sản phẩm */
    .cart-item-card {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 20px;
        margin-bottom: 20px;
        border: 1px solid rgba(0,0,0,0.02);
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        display: flex;
        align-items: center;
    }

        .cart-item-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(168, 213, 186, 0.2);
            border-color: var(--leaf-accent);
        }

    .cart-img-box {
        width: 100px;
        height: 100px;
        border-radius: 18px;
        overflow: hidden;
        flex-shrink: 0;
        background-color: #f0f0f0;
    }

        .cart-img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Bộ điều khiển số lượng Pill Shape */
    .qty-pill {
        background: #F0F4F1;
        border-radius: 50px;
        display: inline-flex;
        align-items: center;
        padding: 4px;
    }

    .qty-btn {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        color: var(--leaf-green);
        text-decoration: none;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        font-weight: bold;
        transition: 0.2s;
    }

        .qty-btn:hover {
            background: var(--leaf-green);
            color: white;
        }

    .qty-val {
        width: 40px;
        text-align: center;
        font-weight: 600;
        color: #333;
        background: transparent;
        border: none;
    }

    /* Bảng tổng tiền */
    .summary-card {
        background: white;
        border-radius: 30px;
        padding: 35px;
        position: sticky;
        top: 100px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.04);
        border: 1px solid rgba(168, 213, 186, 0.3);
    }

    .checkout-btn {
        background-color: var(--leaf-green);
        color: white;
        width: 100%;
        padding: 18px;
        border-radius: 20px;
        font-weight: 700;
        border: none;
        transition: 0.3s;
        display: block;
        text-align: center;
        text-decoration: none;
        font-size: 1.1rem;
    }

        .checkout-btn:hover {
            background-color: #4a6b55;
            color: white;
            box-shadow: 0 10px 25px rgba(90, 125, 101, 0.3);
            transform: translateY(-2px);
        }
</style>

<div class="container py-5">
    <div class="cart-header">
        <h2>Giỏ hàng của bạn <span class="fs-4 text-muted ms-2 fw-normal">(@(Model?.Sum(x => x.SoLuong) ?? 0) sản phẩm)</span></h2>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="row g-5">
            <div class="col-lg-8">
                @foreach (var item in Model)
                {
                    <div class="cart-item-card">
                        <div class="cart-img-box me-4">
                            <img src="@item.HinhAnh" alt="@item.TenHang">
                        </div>

                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="fw-bold mb-1">
                                        <a href="/TrangChu/ChiTiet?id=@item.MaHang" class="text-decoration-none text-dark">@item.TenHang</a>
                                    </h5>
                                    <p class="text-muted small mb-0">Phân loại: Tự nhiên</p>
                                </div>
                                <a asp-controller="GioHang" asp-action="XoaKhoiGio" asp-route-maHang="@item.MaHang"
                                   class="text-danger opacity-50 hover-opacity-100" title="Xóa"
                                   onclick="return confirm('Bạn muốn xóa sản phẩm này?');">
                                    <i class="bi bi-trash3-fill fs-5"></i>
                                </a>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div class="qty-pill">
                                    <a asp-controller="GioHang" asp-action="GiamSoLuong" asp-route-maHang="@item.MaHang" class="qty-btn"><i class="bi bi-dash"></i></a>
                                    <input type="text" class="qty-val" value="@item.SoLuong" readonly>
                                    <a asp-controller="GioHang" asp-action="TangSoLuong" asp-route-maHang="@item.MaHang" class="qty-btn"><i class="bi bi-plus"></i></a>
                                </div>

                                <div class="text-end">
                                    <div class="fw-bold text-success fs-5">@item.ThanhTien.ToString("#,##0") đ</div>
                                    @if (item.SoLuong > 1)
                                    {
                                        <small class="text-muted" style="font-size: 0.8rem;">@item.DonGia.ToString("#,##0") đ / món</small>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="mt-4">
                    <a href="/" class="text-decoration-none fw-bold" style="color: var(--leaf-green);">
                        <i class="bi bi-arrow-left me-1"></i> Tiếp tục xem sản phẩm
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="summary-card">
                    <h4 class="fw-bold mb-4">Tổng đơn hàng</h4>

                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Tạm tính</span>
                        <span>@Model.Sum(x => x.ThanhTien).ToString("#,##0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Vận chuyển</span>
                        <span class="text-success fw-bold">Miễn phí</span>
                    </div>

                    <hr class="my-4" style="border-color: #eee;">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="fw-bold fs-5 text-dark">Tổng cộng</span>
                        <span class="fw-bold fs-3 text-success">@Model.Sum(x => x.ThanhTien).ToString("#,##0") đ</span>
                    </div>

                    <a href="/ThanhToan" class="checkout-btn shadow-sm">
                        Thanh Toán Ngay
                    </a>

                    <div class="mt-4 text-center">
                        <p class="small text-muted mb-2"><i class="bi bi-shield-lock"></i> Thông tin được bảo mật 100%</p>
                        <div class="d-flex justify-content-center gap-2 opacity-50">
                            <i class="bi bi-credit-card-2-front fs-4"></i>
                            <i class="bi bi-qr-code-scan fs-4"></i>
                            <i class="bi bi-cash-coin fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="bg-white rounded-circle d-inline-flex p-4 shadow-sm mb-4">
                <i class="bi bi-basket text-success" style="font-size: 4rem; opacity: 0.5;"></i>
            </div>
            <h3 class="fw-bold text-muted">Giỏ hàng đang trống</h3>
            <p class="text-muted mb-4">Hãy lấp đầy nó bằng những hương thơm tuyệt vời!</p>
            <a href="/" class="btn btn-dark rounded-pill px-5 py-3 fw-bold">
                Mua sắm ngay
            </a>
        </div>
    }
</div>