@model IEnumerable<WebBanMyPham.Models.Hang>
@{
    ViewData["Title"] = "Chăm sóc da";
}

<style>
    .page-hero { padding: 80px 0 40px; text-align: center; }
    .product-grid .card { border: none; background: transparent; }
    .product-img { width:100%; height:320px; object-fit:cover; border-radius:1rem; }
</style>

<div class="container page-hero">
    <h1 class="fw-bold" style="font-size:2.5rem;">Chăm sóc da</h1>
    <p class="text-muted">Dưỡng da dịu nhẹ với thành phần thiên nhiên</p>
</div>

<div class="container product-grid py-4">
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100">
                        <a asp-controller="TrangChu" asp-action="ChiTiet" asp-route-id="@item.MaHang">
                            <img class="product-img" src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/300x400" : item.HinhAnh)" alt="@item.TenHang" />
                        </a>
                        <div class="card-body px-0 pt-2">
                            <h5 class="card-title mb-1"><a asp-controller="TrangChu" asp-action="ChiTiet" asp-route-id="@item.MaHang" class="text-decoration-none">@item.TenHang</a></h5>
                            <p class="text-muted small mb-1">@item.MaLoaiNavigation?.TenLoai</p>
                            <div class="fw-bold">@(item.Gia.HasValue ? item.Gia.Value.ToString("#,##0") : "Liên hệ") ₫</div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted py-5">Chưa có sản phẩm.</div>
        }
    </div>
</div>
