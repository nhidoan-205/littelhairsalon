@model LittleHairSalon.Models.LichDat

@{
    ViewData["Title"] = "Đặt lịch làm tóc";
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<style>
    /* --- CSS CHO TRANG ĐẶT LỊCH - TÔNG VÀNG ĐEN CHUYÊN NGHIỆP --- */
    body { background-color: #000000; color: #ffffff; } /* Nền đen toàn trang */

    .booking-section {
        background-color: #000000; /* Nền đen cực ngầu */
        padding: 60px 0 100px;
        min-height: 80vh;
    }
    .booking-card {
        border: none;
        border-radius: 1.5rem;
        box-shadow: 0 20px 40px -10px rgba(255,215,0,0.1); /* Đổ bóng vàng nhạt */
        overflow: hidden;
        background: #1a1a1a; /* Nền card màu xám cực tối */
        border: 1px solid #333; /* Viền tối */
    }
    
    /* Header của Form: Đổi sang màu vàng, chữ đen cực nổi */
    .booking-header {
        background: #ffd700; /* Màu vàng Gold */
        padding: 40px 30px;
        text-align: center;
    }
    .booking-header h2 {
        color: #000000 !important; /* Chữ tiêu đề màu đen */
        font-weight: 800;
        letter-spacing: -0.5px;
    }
    .booking-header p {
        color: #000000 !important; /* Chữ mô tả màu đen */
    }
    
    /* Style cho các nhãn (Labels) đổi sang trắng */
    .form-group-label {
        font-weight: 700;
        color: #ffffff; /* Chữ trắng */
        margin-bottom: 8px;
        font-size: 0.95rem;
    }
    
    /* Style cho các ô điền thông tin: Nền đen, viền tối */
    .form-control, .form-select {
        border-radius: 0.75rem;
        padding: 12px 16px;
        border: 1.5px solid #333; /* Viền tối */
        background-color: #0a0a0a; /* Nền đen tối hơn */
        transition: all 0.3s ease;
        color: #ffffff; /* Chữ trắng khi gõ */
    }
    /* Khi click vào ô: Hiện viền vàng */
    .form-control:focus, .form-select:focus {
        border-color: #ffd700; /* Viền vàng khi focus */
        background-color: #000000;
        box-shadow: 0 0 0 4px rgba(255, 215, 0, 0.2);
        color: #ffffff;
    }
    /* Style cho placeholder */
    .form-control::placeholder { color: #666; }
    
    /* Nút bấm Submit: Giữ đen, nhưng hover sang vàng */
    .btn-submit-booking {
        background-color: #000000; /* Nút đen */
        color: #ffd700; /* Chữ vàng */
        border-radius: 50px;
        padding: 16px 30px;
        font-weight: 700;
        font-size: 1.1rem;
        width: 100%;
        border: 2px solid #ffd700; /* Viền vàng */
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }
    .btn-submit-booking:hover {
        background-color: #ffd700; /* Hover sang vàng */
        color: #000000; /* Chữ đen */
        transform: translateY(-3px);
        box-shadow: 0 10px 20px -5px rgba(255, 215, 0, 0.4);
    }
    
    /* Màu các câu báo lỗi đổi sang vàng tươi */
    .text-danger { color: #ffeb3b !important; } 
    p.text-muted { color: #aaaaaa !important; } /* Chữ nhỏ dưới form */
    strong { color: #ffffff !important; }
</style>

<section class="booking-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">
                
                <div class="booking-card">
                    <div class="booking-header">
                        <h2 class="mb-2">Đặt Lịch Dịch Vụ</h2>
                        <p class="mb-0">Vui lòng chọn dịch vụ và thời gian bạn mong muốn. Chúng tôi sẽ chuẩn bị không gian tốt nhất cho bạn.</p>
                    </div>
                    
                    <div class="card-body p-4 p-md-5">
                        <form asp-action="Index" method="post">
                            
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="row g-4 mb-4">
                                <div class="col-md-6">
                                    <label class="form-group-label">Chọn Dịch Vụ <span class="text-danger">*</span></label>
                                    <select asp-for="MaDichVu" class="form-select" asp-items="ViewBag.MaDichVu" required>
                                        <option value="">-- Vui lòng chọn --</option>
                                    </select>
                                    <span asp-validation-for="MaDichVu" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-group-label">Stylist / Thợ cắt (Tùy chọn)</label>
                                    <select asp-for="MaNhanVien" class="form-select" asp-items="ViewBag.MaNhanVien">
                                        <option value="">-- Chọn thợ ngẫu nhiên --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row g-4 mb-4">
                                <div class="col-md-6">
                                    <label class="form-group-label">Ngày đến <span class="text-danger">*</span></label>
                                    <input asp-for="NgayDat" type="date" class="form-control" required />
                                    <span asp-validation-for="NgayDat" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-group-label">Giờ đến <span class="text-danger">*</span></label>
                                    <input asp-for="GioDat" type="time" class="form-control" required />
                                    <span asp-validation-for="GioDat" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="mb-5">
                                <label class="form-group-label">Yêu cầu đặc biệt / Ghi chú</label>
                                <textarea asp-for="GhiChu" class="form-control" rows="3" placeholder="Ví dụ: Mình muốn cắt kiểu Side Part rủ, da đầu mình hơi nhạy cảm..."></textarea>
                            </div>

                            <button type="submit" class="btn-submit-booking">
                                <span>XÁC NHẬN ĐẶT LỊCH NGAY</span>
                                <span class="material-symbols-outlined">arrow_right_alt</span>
                            </button>

                        </form>
                    </div>
                </div>

                <div class="text-center mt-4 p.text-muted small">
                    <p><span class="material-symbols-outlined align-middle fs-6 me-1" style="color:#ffd700">info</span> Nếu bạn muốn thay đổi lịch, vui lòng gọi Hotline: <strong>0909.xxx.xxx</strong> trước 1 giờ.</p>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}