@{
    ViewData["Title"] = "Lien He - LittleHairSalon";
}

<style>
    body {
        background-color: #000;
        color: #fff;
    }

    .page-hero {
        background: linear-gradient(180deg, #0a0a00 0%, #000 100%);
        padding: 60px 0 40px;
        text-align: center;
        border-bottom: 1px solid #222;
    }

    .info-card {
        background: #111;
        border: 1px solid #222;
        border-radius: 1.2rem;
        padding: 28px;
        height: 100%;
        transition: 0.3s;
    }

        .info-card:hover {
            border-color: #ffd700;
            transform: translateY(-4px);
            box-shadow: 0 10px 30px rgba(255,215,0,0.08);
        }

    .icon-wrap {
        width: 52px;
        height: 52px;
        background: rgba(255,215,0,0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 16px;
        transition: 0.3s;
    }

    .info-card:hover .icon-wrap {
        background: #ffd700;
    }

    .info-label {
        color: #aaa;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 6px;
    }

    .info-value {
        color: #fff;
        font-weight: 700;
        font-size: 1rem;
    }

        .info-value a {
            color: #ffd700;
            text-decoration: none;
        }

            .info-value a:hover {
                text-decoration: underline;
            }

    .map-wrap {
        border-radius: 1.2rem;
        overflow: hidden;
        border: 1px solid #222;
        height: 420px;
    }

        .map-wrap iframe {
            width: 100%;
            height: 100%;
            border: none;
        }

    .btn-gold {
        background: #ffd700;
        color: #000;
        border: none;
        border-radius: 50px;
        padding: 12px 28px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.2s;
        font-size: 0.95rem;
    }

        .btn-gold:hover {
            background: #fff;
            color: #000;
            transform: translateY(-2px);
        }

    .hours-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #1a1a1a;
        font-size: 0.9rem;
    }

        .hours-row:last-child {
            border-bottom: none;
        }

    .hours-day {
        color: #aaa;
    }

    .hours-time {
        color: #ffd700;
        font-weight: 700;
    }

    .hours-open {
        color: #22c55e;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .social-link {
        color: #fff;
        padding: 10px;
        border-radius: 10px;
        border: 1px solid #222;
        transition: 0.2s;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .social-link:hover {
            border-color: #ffd700;
            color: #fff;
        }
</style>

<div class="page-hero">
    <div class="container">
        <span style="color:#ffd700; font-size:0.85rem; font-weight:700; text-transform:uppercase; letter-spacing:1px;">
            Tìm chúng tôi
        </span>
        <h1 class="fw-bold mt-2 mb-2" style="font-size: 2.8rem;">LittleHair Salon</h1>
        <p style="color:#aaa; max-width:500px; margin:0 auto;">
            Đội ngũ của chúng tôi luôn sẵn sàng hỗ trợ bạn 7 ngày trong tuần.
        </p>
    </div>
</div>

