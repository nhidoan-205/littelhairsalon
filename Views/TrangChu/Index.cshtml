@model IEnumerable<LittleHairSalon.Models.Hang>
@{
    ViewData["Title"] = "Trang chủ - LittleHairSalon";
}

<style>
    /* --- CSS THEO ĐÚNG BẢN STITCH GỐC - ĐÃ ĐỔI TÔNG VÀNG ĐEN --- */
    body { background-color: #000000; color: #ffffff; } /* Nền đen toàn trang */

    .hero-section { position: relative; padding: 60px 0 100px; overflow: hidden; background-color: #000000; }
    
    /* Blob màu đổi sang vàng ánh kim */
    .blob-1 { position: absolute; top: -10%; right: -5%; width: 600px; height: 600px; background-color: rgba(212, 175, 55, 0.2); border-radius: 50%; filter: blur(100px); z-index: -1; }
    .blob-2 { position: absolute; bottom: -10%; left: -5%; width: 400px; height: 400px; background-color: rgba(255, 215, 0, 0.1); border-radius: 50%; filter: blur(80px); z-index: -1; }

    /* Chữ chính màu trắng */
    .hero-title { font-size: clamp(2.5rem, 5vw, 4.5rem); font-weight: 800; color: #ffffff; line-height: 1.1; margin-bottom: 24px; letter-spacing: -1px; }

    .hero-visual-card { border-radius: 2.5rem; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(212, 175, 55, 0.15); position: relative; border: 2px solid #d4af37; }
    .hero-video { width: 100%; min-height: 500px; object-fit: cover; display: block; }
    
    /* Box thông tin nổi bật đổi sang nền đen, viền vàng */
    .hero-info-box { position: absolute; bottom: 30px; left: 30px; right: 30px; background: rgba(26, 26, 26, 0.9); backdrop-filter: blur(8px); padding: 15px 20px; border-radius: 1rem; display: flex; justify-content: space-between; align-items: center; border: 1px solid rgba(212, 175, 55, 0.3); }

    /* Icon các tính năng đổi sang màu vàng */
    .feature-icon { width: 64px; height: 64px; background-color: rgba(212, 175, 55, 0.15); color: #ffd700; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 2rem; transition: 0.3s; }
    .feature-card:hover .feature-icon { background-color: #ffd700; color: #000000; }
    .feature-card { background-color: #1a1a1a !important; border: 1px solid #333; transition: 0.3s; }
    .feature-card:hover { border-color: #ffd700; transform: translateY(-5px); }

    /* --- CARD SẢN PHẨM (STITCH STYLE + HOVER CART) - TÔNG ĐEN VÀNG --- */
    .product-img-box {
        aspect-ratio: 3/4; 
        background-color: #1a1a1a; border-radius: 1.5rem; overflow: hidden; position: relative; border: 1px solid #333;
    }
    .product-img-box img {
        width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease;
    }
    .product-card:hover .product-img-box img { transform: scale(1.05); }
    .product-card:hover { border-color: #ffd700 !important; }

    /* Nút giỏ hàng nổi lên khi hover - Đổi sang màu vàng đen */
    .btn-hover-cart {
        position: absolute; bottom: 15px; right: 15px; width: 45px; height: 45px;
        background-color: #ffd700; color: #000000; border: none; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 15px rgba(255,215,0,0.3); opacity: 0; transform: translateY(10px);
        transition: all 0.3s ease; z-index: 10;
    }
    .product-card:hover .btn-hover-cart { opacity: 1; transform: translateY(0); }
    .btn-hover-cart:hover { background-color: #ffffff; color: #000000; transform: scale(1.1); }
    
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .collection-card {
        min-width: 300px; aspect-ratio: 4/3; border-radius: 1.5rem; overflow: hidden; position: relative; cursor: pointer; border: 1px solid #333;
    }
    media (min-width: 768px) { .collection-card { min-width: 400px; } }
    .collection-card img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease; }
    .collection-card:hover img { transform: scale(1.1); }
    .collection-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.5); transition: 0.3s; }
    .collection-card:hover .collection-overlay { background: rgba(0,0,0,0.2); }
    .collection-content { position: absolute; bottom: 0; left: 0; width: 100%; padding: 30px; }

    /* --- NÚT BẤM - ĐÃ ĐỔI TÔNG VÀNG ĐEN --- */
    /* Nút chính: Nền vàng, chữ đen */
    .btn-main { background-color: #ffd700; color: #000000; font-weight: 700; padding: 12px 32px; border-radius: 50px; text-decoration: none; border: none; transition: 0.3s; display: inline-flex; align-items: center; justify-content: center;}
    .btn-main:hover { background-color: #ffffff; color: #000000; transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgba(255, 215, 0, 0.4); }
    
    /* Nút phụ: Viền vàng, chữ vàng */
    .btn-outline-custom { background: transparent; color: #ffd700; border: 2px solid rgba(255, 215, 0, 0.5); font-weight: 700; padding: 10px 32px; border-radius: 50px; text-decoration: none; transition: 0.3s; display: inline-flex; align-items: center; justify-content: center;}
    .btn-outline-custom:hover { background: rgba(212, 175, 55, 0.1); border-color: #ffd700; color: #ffffff; }

    /* CSS bổ sung để đảm bảo text hiển thị tốt trên nền đen */
    p { color: #aaaaaa; } /* Chữ mô tả màu xám nhạt */
    h3, h4, h5 { color: #ffffff; } /* Tiêu đề màu trắng */
    .text-truncate a { color: #ffffff !important; } /* Tên sản phẩm màu trắng */
    .fw-bold { color: #ffffff !important; } /* Giá tiền màu trắng */
    a { transition: 0.3s; }
</style>

<section class="hero-section">
    <div class="blob-1"></div>
    <div class="blob-2"></div>
    <div class="container relative z-10">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0 pe-lg-5">
                <span class="badge rounded-pill px-4 py-2 mb-4" style="background-color: #ffd700; color: #000000; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;">
                    LittleHairSalon
                </span>
                <h1 class="hero-title">Đánh thức vẻ đẹp tiềm ẩn với phong cách tóc hoàn hảo.</h1>
                <p class="fs-5 mb-5" style="max-width: 500px; line-height: 1.6;">
                    Trải nghiệm dịch vụ làm tóc chuyên nghiệp, tận tâm cùng đội ngũ Stylist hàng đầu. Thay đổi diện mạo - Nâng tầm phong cách.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/DatLich" class="btn-main"><span class="material-symbols-outlined me-2 fs-5">calendar_month</span> Đặt lịch cắt tóc</a>
                    <a href="#dich-vu" class="btn-outline-custom">Khám phá dịch vụ</a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-visual-card">
                    <img src="https://images.unsplash.com/photo-1560066984-138dadb4c035?q=80&w=1000&auto=format&fit=crop" class="hero-video" alt="Hair Salon Experience">
                    <div class="hero-info-box shadow-sm">
                        <div>
                            <p class="mb-0 fw-bold fs-6" style="color: #ffffff !important;">Combo Cắt & Gội</p>
                            <p class="mb-0 small" style="color: #aaaaaa;">Thư giãn 45 phút</p>
                        </div>
                        <span class="badge rounded-pill px-3 py-2" style="background-color: #ffd700; color: #000000; font-size: 0.85rem;">Từ 150.000₫</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5" style="background-color: #0a0a0a;">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h3 class="fw-bold mb-3" style="font-size: 2.2rem;">Tại sao chọn LittleHairSalon?</h3>
            <p style="max-width: 700px; margin: 0 auto; line-height: 1.6;">Chúng tôi không chỉ cắt tóc, chúng tôi kiến tạo nên sự tự tin của bạn thông qua không gian chuyên nghiệp và sản phẩm chất lượng cao.</p>
        </div>
        <div class="row g-4 mt-2">
            <div class="col-md-4">
                <div class="feature-card text-center bg-white p-5 rounded-4 shadow-sm h-100 transition" style="transition: 0.3s;">
                    <div class="feature-icon"><span class="material-symbols-outlined">content_cut</span></div>
                    <h5 class="fw-bold mb-3">Stylist Chuyên Nghiệp</h5>
                    <p class="small mb-0" style="line-height: 1.6;">Đội ngũ thợ tóc dày dặn kinh nghiệm, liên tục cập nhật những xu hướng và kỹ thuật cắt mới nhất.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card text-center bg-white p-5 rounded-4 shadow-sm h-100 transition" style="transition: 0.3s;">
                    <div class="feature-icon"><span class="material-symbols-outlined">verified</span></div>
                    <h5 class="fw-bold mb-3">Mỹ Phẩm Cao Cấp</h5>
                    <p class="small mb-0" style="line-height: 1.6;">Cam kết sử dụng 100% các sản phẩm gội, uốn, nhuộm, sáp vuốt tóc chính hãng bảo vệ da đầu.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card text-center bg-white p-5 rounded-4 shadow-sm h-100 transition" style="transition: 0.3s;">
                    <div class="feature-icon"><span class="material-symbols-outlined">spa</span></div>
                    <h5 class="fw-bold mb-3">Không Gian Thư Giãn</h5>
                    <p class="small mb-0" style="line-height: 1.6;">Hệ thống ghế massage và không gian âm nhạc nhẹ nhàng giúp bạn đánh bay mệt mỏi sau ngày dài.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="san-pham" class="container py-5 mt-5">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h3 class="fw-bold" style="font-size: 2.2rem;">Sản Phẩm Chăm Sóc Tóc</h3>
            <p class="mb-0 mt-2">Các dòng sáp vuốt, gôm xịt và dầu gội đang được sử dụng trực tiếp tại Salon.</p>
        </div>
        <a href="/HangHoa/TatCa" class="text-decoration-none fw-bold d-none d-md-flex align-items-center gap-1" style="color: #ffd700 !important;">
            Xem tất cả sản phẩm <span class="material-symbols-outlined fs-6">arrow_forward</span>
        </a>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model.Take(4))
            {
                <div class="col">
                    <div class="card product-card border border-dark h-100" style="background-color: #000; transition: 0.3s; border-radius: 1.5rem;">
                        <div class="product-img-box mb-3 shadow-sm position-relative">
                            <a asp-controller="HangHoa" asp-action="ChiTiet" asp-route-id="@item.MaHang" class="d-block w-100 h-100">
                                <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/300x400" : (item.HinhAnh.StartsWith("http") ? item.HinhAnh : "/" + item.HinhAnh.TrimStart('/')))" alt="@item.TenHang">
                            </a>
                            <button type="button" onclick="themVaoGioAjax(@item.MaHang, this)" class="btn-hover-cart" title="Thêm vào giỏ">
                                <span class="material-symbols-outlined">add_shopping_cart</span>
                            </button>
                        </div>
                        <div class="px-3 pb-3">
                            <h5 class="fw-bold text-truncate mb-1" style="font-size: 1.1rem;">
                                <a asp-controller="HangHoa" asp-action="ChiTiet" asp-route-id="@item.MaHang" class="text-decoration-none" style="color: inherit;">
                                    @item.TenHang
                                </a>
                            </h5>
                            <p class="small mb-2" style="color: #aaaaaa;">
                                @(item.MaLoaiNavigation?.TenLoai ?? "Sản phẩm")
                            </p>
                            <div class="fw-bold" style="color: #ffd700 !important; font-size: 1.05rem;">
                                @(item.Gia.HasValue ? item.Gia.Value.ToString("#,##0") : "Liên hệ") ₫
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</section>

<section id="dich-vu" class="py-5 mt-4" style="background-color: #0a0a0a;">
    <div class="container py-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
            <div>
                <span class="fw-bold text-uppercase" style="color: #ffd700; font-size: 0.85rem; letter-spacing: 1px;">Khám Phá Bảng Giá</span>
                <h3 class="fw-bold mt-2 mb-0" style="font-size: 2.5rem;">Dịch Vụ Nổi Bật</h3>
            </div>
            <div class="d-flex gap-3">
                <button id="btn-scroll-left" class="btn btn-outline-custom rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; padding: 0;"><span class="material-symbols-outlined">arrow_back</span></button>
                <button id="btn-scroll-right" class="btn btn-main rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; padding: 0;"><span class="material-symbols-outlined">arrow_forward</span></button>
            </div>
        </div>

        <div id="collection-scroll" class="d-flex gap-4 overflow-x-auto pb-4 hide-scrollbar" style="scroll-snap-type: x mandatory; scroll-behavior: smooth;">
            <div class="collection-card flex-shrink-0 shadow-sm" style="scroll-snap-align: center;">
                <img src="https://images.unsplash.com/photo-1599351431202-1e0f0137899a?q=80&w=800&auto=format&fit=crop" alt="Cắt Tóc Nam">
                <div class="collection-overlay"></div>
                <div class="collection-content">
                    <h4 class="fw-bold text-white mb-2 fs-3">Tạo Kiểu Nam</h4>
                    <p class="text-white opacity-75 small mb-3">Tư vấn kiểu tóc phù hợp khuôn mặt, cắt, gội massage và vuốt sáp tạo kiểu.</p>
                    <a href="/DatLich" class="fw-bold small border-bottom pb-1 text-decoration-none" style="color: #ffd700 !important; border-color: #ffd700 !important;">Đặt lịch ngay</a>
                </div>
            </div>
            
            <div class="collection-card flex-shrink-0 shadow-sm" style="scroll-snap-align: center;">
                <img src="https://m.yodycdn.com/blog/cac-kieu-uon-toc-nu-dep-yodyvn4.jpg" alt="Uốn Nhuộm Nữ">
                <div class="collection-overlay"></div>
                <div class="collection-content">
                    <h4 class="fw-bold text-white mb-2 fs-3">Uốn / Nhuộm Thời Trang</h4>
                    <p class="text-white opacity-75 small mb-3">Sử dụng thuốc nhuộm organic an toàn, lên màu chuẩn, giữ nếp lâu dài.</p>
                    <a href="/DatLich" class="fw-bold small border-bottom pb-1 text-decoration-none" style="color: #ffd700 !important; border-color: #ffd700 !important;">Đặt lịch ngay</a>
                </div>
            </div>
            
            <div class="collection-card flex-shrink-0 shadow-sm" style="scroll-snap-align: center;">
                <img src="https://tse1.explicit.bing.net/th/id/OIP.5iMwpZzqLyAVirBy37-rPAHaET?rs=1&pid=ImgDetMain&o=7&rm=3" alt="Gội Đầu Dưỡng Sinh">
                <div class="collection-overlay"></div>
                <div class="collection-content">
                    <h4 class="fw-bold text-white mb-2 fs-3">Gội Đầu Dưỡng Sinh</h4>
                    <p class="text-white opacity-75 small mb-3">Thư giãn, đả thông kinh lạc và chăm sóc da đầu với thảo dược thiên nhiên.</p>
                    <a href="/DatLich" class="fw-bold small border-bottom pb-1 text-decoration-none" style="color: #ffd700 !important; border-color: #ffd700 !important;">Đặt lịch ngay</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5" style="background-color: #000000;">
    <div class="container py-5 my-5">
        <div class="text-center mx-auto" style="max-width: 800px; border: 2px solid #333; padding: 50px; border-radius: 2rem;">
            <h2 class="fw-bold mb-4" style="font-size: 2.8rem;">Sẵn sàng lột xác với diện mạo mới?</h2>
            <p class="fs-5 mb-5">Đặt lịch ngay hôm nay để không phải chờ đợi và nhận ưu đãi giảm 10% cho khách hàng mới.</p>
            <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                <a href="/DatLich" class="btn-main px-5 py-3 fs-6">Đặt Lịch Cắt Tóc</a>
                <a href="/HangHoa/TatCa" class="btn-outline-custom px-5 py-3 fs-6">Mua Sáp & Dầu Gội</a>
            </div>
        </div>
    </div>
</section>

<!-- ĐÁNH GIÁ KHÁCH HÀNG -->
<section class="py-5" style="background-color: #0a0a0a;">
    <div class="container py-4">
        <div class="text-center mb-5">
            <span style="color:#ffd700; font-size:0.85rem; font-weight:700; text-transform:uppercase; letter-spacing:1px;">
				⭐ Mong bạn góp ý và đánh giá để chúng tôi ngày càng hoàn thiện hơn! ⭐
            </span>
            <h3 class="fw-bold mt-2" style="font-size:2rem;">Đánh Giá & Nhận Xét</h3>
        </div>

        <!-- Danh sách đánh giá -->
        <div id="danh-sach-danh-gia" class="row g-4 mb-5">
            <!-- Load bằng JS -->
        </div>

        <!-- Form đánh giá -->
        <div class="mx-auto" style="max-width:600px; background:#111; border:1px solid #222; border-radius:1.2rem; padding:2rem;">
            <h5 class="fw-bold mb-4" style="color:#ffd700;">✍️ Viết đánh giá của bạn</h5>

            @if (TempData["DanhGiaOK"] != null)
            {
                <div class="alert" style="background:#0f2a0f; border:1px solid #22c55e; color:#22c55e; border-radius:8px; padding:12px; margin-bottom:16px;">
                    ✅ @TempData["DanhGiaOK"]
                </div>
            }

            <form action="/DanhGia/GuiDanhGia" method="post">
                <!-- Chọn sao -->
                <div class="mb-4">
                    <label style="color:#aaa; font-size:0.85rem; margin-bottom:8px; display:block;">Đánh giá của bạn</label>
                    <div id="star-selector" style="display:flex; gap:8px; font-size:2rem; cursor:pointer;">
                        <span data-val="1" style="color:#333;">★</span>
                        <span data-val="2" style="color:#333;">★</span>
                        <span data-val="3" style="color:#333;">★</span>
                        <span data-val="4" style="color:#333;">★</span>
                        <span data-val="5" style="color:#333;">★</span>
                    </div>
                    <input type="hidden" name="SoSao" id="SoSao" value="5">
                </div>

                <!-- Tên -->
                <div class="mb-3">
                    <input type="text" name="HoTen" placeholder="Tên của bạn..."
                           value="@(Context.Session.GetString("TenDangNhap") ?? "")"
                           required
                           style="width:100%; background:#1a1a1a; border:1px solid #333; color:#fff; border-radius:8px; padding:12px 16px; outline:none; font-size:0.9rem;">
                </div>

                <!-- Nội dung -->
                <div class="mb-4">
                    <textarea name="NoiDung" placeholder="Chia sẻ trải nghiệm của bạn tại LittleHairSalon..." required rows="3"
                              style="width:100%; background:#1a1a1a; border:1px solid #333; color:#fff; border-radius:8px; padding:12px 16px; outline:none; font-size:0.9rem; resize:none;"></textarea>
                </div>

                <button type="submit"
                        style="background:#ffd700; color:#000; border:none; border-radius:50px; padding:12px 32px; font-weight:700; width:100%; font-size:0.95rem; cursor:pointer; transition:0.2s;">
                    Gửi đánh giá ⭐
                </button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Scroll dịch vụ
            const scrollContainer = document.getElementById("collection-scroll");
            const btnLeft = document.getElementById("btn-scroll-left");
            const btnRight = document.getElementById("btn-scroll-right");
            if (btnLeft && btnRight && scrollContainer) {
                btnLeft.addEventListener("click", () => scrollContainer.scrollBy({ left: -350, behavior: "smooth" }));
                btnRight.addEventListener("click", () => scrollContainer.scrollBy({ left: 350, behavior: "smooth" }));
            }

            // Load đánh giá
            fetch('/DanhGia/DanhSach')
                .then(r => r.json())
                .then(data => {
                    const container = document.getElementById('danh-sach-danh-gia');
                    if (!data || data.length === 0) {
                        container.innerHTML = '<div class="col-12 text-center" style="color:#555;">Chua co danh gia nao. Hay la nguoi dau tien!</div>';
                        return;
                    }
                    container.innerHTML = data.slice(0, 6).map(d => `
                        <div class="col-md-4">
                            <div style="background:#111; border:1px solid #222; border-radius:1rem; padding:20px; height:100%;">
                                <div style="color:#ffd700; font-size:1.2rem; margin-bottom:8px;">
                                    ${'★'.repeat(d.soSao)}${'☆'.repeat(5 - d.soSao)}
                                </div>
                                <p style="color:#ddd; font-size:0.9rem; line-height:1.6; margin-bottom:12px;">"${d.noiDung}"</p>
                                <div style="color:#ffd700; font-weight:700; font-size:0.9rem;">— ${d.hoTen}</div>
                                <div style="color:#555; font-size:0.75rem;">${new Date(d.ngayDang).toLocaleDateString('vi-VN')}</div>
                            </div>
                        </div>
                    `).join('');
                });

            // Star selector
            const stars = document.querySelectorAll('#star-selector span');
            let selectedStar = 5;
            stars.forEach(s => {
                s.style.color = '#ffd700';
                s.addEventListener('mouseover', function() {
                    const val = parseInt(this.dataset.val);
                    stars.forEach((st, i) => st.style.color = i < val ? '#ffd700' : '#333');
                });
                s.addEventListener('mouseout', function() {
                    stars.forEach((st, i) => st.style.color = i < selectedStar ? '#ffd700' : '#333');
                });
                s.addEventListener('click', function() {
                    selectedStar = parseInt(this.dataset.val);
                    document.getElementById('SoSao').value = selectedStar;
                });
            });
        });
    </script>
}