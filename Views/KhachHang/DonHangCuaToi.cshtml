
@{
    ViewData["Title"] = "Đơn Hàng Của Tôi";
}

@using System.Linq
@model IEnumerable<LittleHairSalon.Models.DonHang>

<div class="container mt-5 mb-5" style="min-height: 600px;">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-success">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Đơn hàng của tôi</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">Đơn hàng của tôi</h2>
        <span class="badge bg-light text-dark border">@Model.Count() đơn hàng</span>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 shadow-sm rounded bg-white">
            <img src="https://cdn-icons-png.flaticon.com/512/11329/11329073.png" style="width: 100px; opacity: 0.5;" alt="Empty">
            <p class="mt-3 text-muted">Bạn chưa có đơn hàng nào.</p>
            <a href="/" class="btn btn-success rounded-pill px-4">Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Người nhận</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#@item.MaDon</td>
                                <td>@item.NgayDat?.ToString("dd/MM/yyyy")</td>
                                <td>@item.NguoiNhan</td>
                                <td>
                                    <span class="fw-bold text-success">@item.TongTien?.ToString("#,##0") đ</span>
                                </td>
                                <td>
                                    @if(item.TrangThai == "Mới") {
                                        <span class="badge bg-info text-dark rounded-pill">Chờ xác nhận</span>
                                    } else {
                                        <span class="badge bg-light text-dark border rounded-pill">@item.TrangThai</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-controller="KhachHang"
                                       asp-action="ChiTietDonHang"
                                       asp-route-id="@item.MaDon"
                                       class="btn btn-sm btn-outline-success rounded-pill px-3">
                                        Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    
    .table thead th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        color: #555;
        border-bottom: none;
        padding: 15px 10px;
    }
    .table tbody td {
        padding: 15px 10px;
        border-color: #f8f9fa;
    }
    .card {
        border-radius: 15px;
        overflow: hidden;
    }
</style>