@model LittleHairSalon.Models.DichVu
@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container p-4" style="background-color: #1a1a1a; color: white; border-radius: 15px; max-width: 700px;">
    <h3 style="color: #ffcc00;">CẬP NHẬT THÔNG TIN DỊCH VỤ</h3>
    <hr class="border-secondary" />
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label class="form-label fw-bold">Tên dịch vụ</label>
            <input asp-for="TenDichVu" class="form-control bg-dark text-white border-secondary" />
            <span asp-validation-for="TenDichVu" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Giá tiền</label>
                <input asp-for="Gia" type="number" class="form-control bg-dark text-white border-secondary" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Thời gian (phút)</label>
                <input asp-for="ThoiGianUocTinh" type="number" class="form-control bg-dark text-white border-secondary" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Hình ảnh dịch vụ</label>
            <input type="file" name="fAnh" class="form-control bg-dark text-white border-secondary" accept="image/*" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Mô tả dịch vụ</label>
            <textarea asp-for="MoTa" rows="3" class="form-control bg-dark text-white border-secondary"></textarea>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-warning fw-bold px-4">LƯU LẠI</button>
            <a asp-action="Index" class="btn btn-outline-light ms-2">HỦY</a>
        </div>
    </form>
</div>