@model LittleHairSalon.Models.LichDat
@{
    ViewData["Title"] = "Chi Tiết Lịch Hẹn";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div style="max-width: 700px;">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/LichDat" class="btn btn-outline-secondary btn-sm rounded-pill">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
        <h5 class="fw-bold mb-0">Chi Tiết Lịch Hẹn #@Model.MaLichDat</h5>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <table class="table table-bordered">
                <tr>
                    <th style="width:180px; background:#f8f9fa;">Mã lịch</th>
                    <td>#@Model.MaLichDat</td>
                </tr>
                <tr>
                    <th style="background:#f8f9fa;">Khách hàng</th>
                    <td>@(Model.KhachHang?.HoTen ?? "Không rõ")</td>
                </tr>
                <tr>
                    <th style="background:#f8f9fa;">Dịch vụ</th>
                    <td>@(Model.DichVu?.TenDichVu ?? "Không rõ")</td>
                </tr>
                <tr>
                    <th style="background:#f8f9fa;">Nhân viên</th>
                    <td>@(Model.NhanVien?.TenNhanVien ?? "Chưa chỉ định")</td>
                </tr>
                <tr>
                    <th style="background:#f8f9fa;">Ngày hẹn</th>
                    <td>@Model.NgayDat?.ToString("dd/MM/yyyy")</td>
                </tr>
                <tr>
                    <th style="background:#f8f9fa;">Giờ hẹn</th>
                    <td>@Model.GioDat?.ToString(@"hh\:mm")</td>
                </tr>
                <tr>
                    <th style="background:#f8f9fa;">Ghi chú</th>
                    <td>@(string.IsNullOrEmpty(Model.GhiChu) ? "Không có" : Model.GhiChu)</td>
                </tr>
                <tr>
                    <th style="background:#f8f9fa;">Trạng thái</th>
                    <td>
                        @switch (Model.TrangThai)
                        {
                            case 1:
                                <span class="badge bg-success">Đã xác nhận</span>
                                break;
                            case 2:

                                <span class="badge bg-info">Hoàn thành</span>
                                break;
                            case 3:

                                <span class="badge bg-danger">Đã hủy</span>
                                break;
                            default:

                                <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                break;
                        }
                    </td>
                </tr>
                <tr>
                    <th style="background:#f8f9fa;">Ngày tạo</th>
                    <td>@Model.NgayTaoLich.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            </table>

            @if (Model.TrangThai == 0)
            {
                <div class="d-flex gap-2 mt-3">
                    <a href="/Admin/LichDat/XacNhan/@Model.MaLichDat"
                       class="btn btn-success"
                       onclick="return confirm('Xác nhận duyệt lịch này?')">
                        ✅ Duyệt lịch
                    </a>
                    <a href="/Admin/LichDat/HuyLich/@Model.MaLichDat"
                       class="btn btn-danger"
                       onclick="return confirm('Xác nhận hủy lịch này?')">
                        ❌ Hủy lịch
                    </a>
                </div>
            }
        </div>
    </div>
</div>