@model LittleHairSalon.Models.Hang
@{
    ViewData["Title"] = "Thêm Sản Phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-primary text-white py-3 rounded-top-4">
                <h5 class="mb-0 fw-bold"><i class="bi bi-plus-lg me-2"></i>Thêm Sản Phẩm Mới</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="ThemSanPham" method="post">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Tên sản phẩm</label>
                            <input asp-for="TenHang" class="form-control rounded-3" placeholder="Nhập tên sản phẩm..." required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Loại sản phẩm</label>
                            <select asp-for="MaLoai" class="form-select rounded-3" asp-items="ViewBag.MaLoai">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                            <input asp-for="Gia" type="number" class="form-control rounded-3" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Link Hình Ảnh</label>
                            <input asp-for="HinhAnh" class="form-control rounded-3" placeholder="https://..." />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Mô tả sản phẩm</label>
                            <textarea asp-for="MoTa" class="form-control rounded-3" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 fw-bold">Lưu Sản Phẩm</button>
                        <a asp-action="QuanLySanPham" class="btn btn-light px-4">Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>