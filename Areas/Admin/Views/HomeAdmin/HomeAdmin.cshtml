@model LittleHairSalon.Models.Hang
@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới";
    // Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml"; // Mở dòng này nếu bạn có layout riêng cho Admin
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-primary text-white rounded-top-4">
            <h5 class="mb-0 fw-bold"><i class="bi bi-box-seam"></i> Thêm Sản Phẩm Mới</h5>
        </div>
        
        <div class="card-body p-4">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <form asp-area="Admin" asp-controller="HomeAdmin" asp-action="ThemSanPham" method="POST">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tên sản phẩm</label>
                        <input asp-for="TenHang" class="form-control" placeholder="Nhập tên..." required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Loại sản phẩm</label>
                        <select asp-for="MaLoai" class="form-select" asp-items="ViewBag.MaLoai" required>
                            <option value="">-- Chọn loại --</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                        <input asp-for="Gia" type="number" class="form-control" placeholder="1500000" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Đường dẫn Hình Ảnh</label>
                        <input asp-for="HinhAnh" class="form-control" placeholder="/images/ten-anh.jpg hoặc link web" />
                    </div>

                    <div class="col-12 mb-4">
                        <label class="form-label fw-bold">Mô tả chi tiết</label>
                        <textarea asp-for="MoTa" class="form-control" rows="4" placeholder="Nhập mô tả..."></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success fw-bold px-4">
                        <i class="bi bi-save"></i> Lưu Sản Phẩm
                    </button>
                    <a asp-area="Admin" asp-controller="HomeAdmin" asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>