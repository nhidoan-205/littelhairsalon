@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Trị LittleHairSalon</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            background-color: #f4f6f9;
            margin: 0;
        }

        .sidebar {
            width: 250px;
            background: #1e2a35;
            min-height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
            overflow-y: auto;
        }

        .sidebar-header {
            padding: 24px 20px;
            background: #151f28;
            text-align: center;
            border-bottom: 1px solid #2c3e50;
        }

        .sidebar-menu {
            padding: 12px 0;
        }

        .sidebar a {
            padding: 12px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: #95a5a6;
            text-decoration: none;
            border-left: 3px solid transparent;
            transition: 0.2s;
            font-size: 0.9rem;
            font-weight: 500;
        }

            .sidebar a:hover {
                background: #2c3e50;
                color: #fff;
                border-left-color: #1abc9c;
            }

            .sidebar a.active {
                background: #2c3e50;
                color: #fff;
                border-left-color: #1abc9c;
            }

            .sidebar a i {
                font-size: 1rem;
                width: 20px;
                text-align: center;
            }

        .sidebar hr {
            border-color: #2c3e50;
            margin: 8px 16px;
        }

        .main-content {
            margin-left: 250px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .admin-topbar {
            background: #fff;
            padding: 14px 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #edf2f7;
            position: sticky;
            top: 0;
            z-index: 99;
        }

        .admin-body {
            padding: 28px;
            flex: 1;
        }

        .avatar-circle {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: #1abc9c;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    @{
        string currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        string tenDangNhap = Context.Session?.GetString("TenDangNhap") ?? "Admin";
        string initial = tenDangNhap.Length > 0 ? tenDangNhap[0].ToString().ToUpper() : "A";
    }

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-header">
            <h5 class="fw-bold mb-0 text-white">✂️ LittleHair</h5>
            <span class="badge bg-info mt-1">Admin</span>
        </div>

        <div class="sidebar-menu">
            <a href="/Admin/HomeAdmin" class="@(currentController == "HomeAdmin" ? "active" : "")">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
            <a href="/Admin/LichDat" class="@(currentController == "LichDat" ? "active" : "")">
                <i class="bi bi-calendar-check"></i> Quản lý Lịch hẹn
            </a>
            <a href="/Admin/DichVus" class="@(currentController == "DichVus" ? "active" : "")">
                <i class="bi bi-scissors"></i> Quản lý Dịch vụ
            </a>
            <a href="/Admin/NhanViens" class="@(currentController == "NhanViens" ? "active" : "")">
                <i class="bi bi-person-badge"></i> Quản lý Nhân viên
            </a>
            <a href="/Admin/KhachHangs" class="@(currentController == "KhachHangs" ? "active" : "")">
                <i class="bi bi-people"></i> Khách hàng
            </a>

            <hr />

            <a href="/TrangChu" target="_blank">
                <i class="bi bi-shop"></i> Xem trang chủ
            </a>
            <a href="/TaiKhoan/DangXuat" style="color: #e74c3c;">
                <i class="bi bi-box-arrow-right"></i> Đăng xuất
            </a>
        </div>
    </div>

    <!-- MAIN -->
    <div class="main-content">

        <!-- TOPBAR -->
        <div class="admin-topbar">
            <div>
                <h6 class="mb-0 fw-bold text-dark">@ViewData["Title"]</h6>
                <small class="text-muted">LittleHairSalon Admin</small>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted" style="font-size:0.85rem;">
                    <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dd/MM/yyyy")
                </span>
                <div class="d-flex align-items-center gap-2">
                    <div class="avatar-circle">@initial</div>
                    <span class="fw-bold" style="font-size:0.9rem;">@tenDangNhap</span>
                </div>
            </div>
        </div>

        <!-- BODY -->
        <div class="admin-body">
            @RenderBody()
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>